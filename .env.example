# Copy to .env.local next to the project or exe. Do not commit real credentials.

TW_WATCH_MARKET_DATA_MODE=live
TW_WATCH_TIMEZONE=Asia/Taipei
TW_WATCH_POLL_SECONDS=60
TW_WATCH_STALE_SECONDS=70
# Optional: point the app to a separate SQLite DB, e.g. data/trading_lab_demo.sqlite3
TW_WATCH_DB_PATH=
TW_WATCH_DAYTRADE_ELIGIBLE_SYMBOLS_FILE=data/daytrade_eligible_symbols.txt
TW_WATCH_ENABLE_AUTO_SCOUT=false
TW_WATCH_AUTO_SCOUT_TIME=09:05
TW_WATCH_SCOUT_MAX_DAYTRADE=5
TW_WATCH_SCOUT_MAX_SWING=5
TW_WATCH_SCOUT_EXCLUDED_SYMBOLS_FILE=data/scout_excluded_symbols.txt
TW_WATCH_ENABLE_CODEX_LLM=false
TW_WATCH_ENABLE_SWING_SELF_CORRECTION=false
TW_WATCH_ENABLE_MULTI_AGENT_REVIEW=false
TW_WATCH_ENABLE_NEWS_CONTEXT=false
TW_WATCH_LLM_BACKEND=codex_cli
TW_WATCH_CODEX_MODEL=gpt-5.5
TW_WATCH_CODEX_TIMEOUT_SECONDS=60
# Optional when TW_WATCH_LLM_BACKEND=openai_api or anthropic_api.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Taishin Nova
TAISHIN_NOVA_USER=
TAISHIN_NOVA_PASSWORD=
TAISHIN_NOVA_CERT_PATH=
TAISHIN_NOVA_CERT_PASSWORD=
TAISHIN_NOVA_QUOTE_WAIT_SECONDS=8
